  "advancement.tcc.tcc_root.title": "TACZ饰品",
  "advancement.tcc.tcc_root.description": "TACZ饰品",
  "advancement.tcc.my_island.title": "我的小岛",
  "advancement.tcc.my_island.description": "你不要再和我提小岛的事啦……我已经不在意了，真的。",
  "advancement.tcc.xiora_mission.title": "夜袭强敌",
  "advancement.tcc.xiora_mission.description": "总觉得晚上出门更安全……可能这就是职业病吧。",
  "advancement.tcc.thunder_seen.title": "雷光初现",
  "advancement.tcc.thunder_seen.description": "鸣神",
  "advancement.tcc.xiora_to_raven.title": "夜袭渡鸦",
  "advancement.tcc.xiora_to_raven.description": "诛愆尤",
  "advancement.tcc.raven_to_island.title": "七雷召唤",
  "advancement.tcc.raven_to_island.description": "让我数数，这里有一个律者，两个律者……唔，真有你的啊。",
  "advancement.tcc.summer_beach_grant.title": "凯文",
  "advancement.tcc.summer_beach_grant.description": "@灰蛇，你给我把字数限制关掉。",
  "advancement.tcc.summer_to_brahma.title": "进化：无烬之剑",
  "advancement.tcc.summer_to_brahma.description": "梵天百兽，加诸此身……「业魔」入渊，「救世」拔剑！",
  "advancement.tcc.brahma_to_salvation.title": "进化：救赎",
  "advancement.tcc.brahma_to_salvation.description": "此即——‘救世’之铭！",
  "advancement.tcc.judgment_to_apocalypse.title": "进化：天火劫灭",
  "advancement.tcc.judgment_to_apocalypse.description": "那么，鸟为什么会飞？",
  "advancement.tcc.judgement_key.title": "裁决",
  "advancement.tcc.judgement_key.description": "伏逆戈",
  "advancement.tcc.heaven_fire_apocalypse_endless.title": "劫灭无尽",
  "advancement.tcc.heaven_fire_apocalypse_endless.description": "星煌",
  "advancement.tcc.griseo_grant.title": "生命的色彩",
  "advancement.tcc.griseo_grant.description": "星星们，和月亮住在一起，在很高很高的天上……",
  "advancement.tcc.qianjie_yicheng_grant.title": "千界一乘",
  "advancement.tcc.qianjie_yicheng_grant.description": "星空，很美。想把它留在这里……留在我的画里。",
  "advancement.tcc.griseo_to_huishi_zhijuan.title": "进化：绘世之卷",
  "advancement.tcc.griseo_to_huishi_zhijuan.description": "唔……画笔，会自己画画吗？它会想画什么出来呢？",
  "advancement.tcc.qianjie_to_yongjie_zhijian.title": "进化：永劫之键",
  "advancement.tcc.qianjie_to_yongjie_zhijian.description": "笔、笔在自己画画！啊……好可惜，是梦啊。",
  "advancement.tcc.huishi_to_fanxing.title": "进化：繁星·视界反演",
  "advancement.tcc.huishi_to_fanxing.description": "到截稿时间了？可是，我才刚刚启动数位屏啊。",
  "advancement.tcc.shijie_fanyan_grant.title": "视界反演",
  "advancement.tcc.shijie_fanyan_grant.description": "航行无异常，可以睡……嗯？今天就是截稿日？好吧。",
  "advancement.tcc.kalpas_grant.title": "千劫",
  "advancement.tcc.kalpas_grant.description": "你来的太迟了，「后继者」。",
  "advancement.tcc.imer_grant.title": "伊默尔",
  "advancement.tcc.imer_grant.description": "你的名字并不重要，律者。",
  "advancement.tcc.kalpas_to_huajie_zhiyan.title": "进化：坏劫之焱",
  "advancement.tcc.kalpas_to_huajie_zhiyan.description": "烈火，在灼烧。灼烧着一切，吞噬着一切，毁灭着一切。",
  "advancement.tcc.imer_to_dominance_key.title": "进化：支配之键",
  "advancement.tcc.imer_to_dominance_key.description": "尽敌鏖杀，无止无休！",
  "advancement.tcc.huajie_to_aomie.title": "进化：鏖灭",
  "advancement.tcc.huajie_to_aomie.description": "谁***又来***偷吃我的东西？！！！",
  "advancement.tcc.meta_morph_grant.title": "Meta-Morph",
  "advancement.tcc.meta_morph_grant.description": "孤独的美食家",
  "advancement.tcc.su_grant.title": "苏",
  "advancement.tcc.su_grant.description": "欢迎，来访者。",
  "advancement.tcc.wanwu_xiumian_grant.title": "万物休眠",
  "advancement.tcc.wanwu_xiumian_grant.description": "尘归尘，土归土。",
  "advancement.tcc.juezhe_grant.title": "觉者",
  "advancement.tcc.juezhe_grant.description": "以此「天慧」，授予你踏破试炼之理。",
  "advancement.tcc.tingzhi_zhijian_grant.title": "停滞之键",
  "advancement.tcc.tingzhi_zhijian_grant.description": "愿往日的枯壤，化作幼芽新生的温床。",
  "advancement.tcc.tianhui_grant.title": "天慧",
  "advancement.tcc.tianhui_grant.description": "万千因果线，皆系于此间。",
  "advancement.tcc.yinguo_zhuanlun_grant.title": "因果转轮",
  "advancement.tcc.yinguo_zhuanlun_grant.description": "愿此「天慧」之刻印，能为你指明前行的方向。",
  "advancement.tcc.vill_v_grant.title": "VILL-V",
  "advancement.tcc.vill_v_grant.description": "放心吧，问题总会解决的——至少它总能解决我们嘛。",
  "advancement.tcc.xukong_wancang_grant.title": "虚空万藏",
  "advancement.tcc.xukong_wancang_grant.description": "不过······今天休演哦？",
  "advancement.tcc.yuxi_zhixia_grant.title": "愚戏之匣",
  "advancement.tcc.yuxi_zhixia_grant.description": "「凯文毁灭按钮」！",
  "advancement.tcc.qishi_zhijian_grant.title": "启示之键",
